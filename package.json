{
    "name": "@erosire/story-generator",
    "version": "1.0.0",
    "description": "Story Generator for Deployment",
    "type": "module",
    "main": "src/main.tsx",
    "scripts": {
        "dev": "vite --host",
        "build": "vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest",
