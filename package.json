    "dependencies": {
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@vitejs/plugin-react": "^6.0.1",
        "gh-pages": "^6.3.0",
        "jsdom": "^29.0.2",
        "typescript": "^6.0.0",
        "vite": "^8.0.8",
        "vite-node": "^6.0.0",
        "vitest": "^4.1.4"
    }
}
